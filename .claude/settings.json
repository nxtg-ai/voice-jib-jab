{
  "model": "claude-opus-4-8",
  "version": "3.0.0",
  "theme": "dark",
  "editor": {
    "tab_size": 2,
    "insert_spaces": true,
    "auto_save": true,
    "format_on_save": false
  },
  "terminal": {
    "font_size": 14,
    "cursor_blink": true
  },
  "notifications": {
    "enabled": true,
    "sound": false,
    "desktop": true
  },
  "ai": {
    "auto_suggestions": true,
    "inline_completions": false,
    "code_review_on_save": false
  },
  "workspace": {
    "auto_open_files": [],
    "sidebar_visible": true,
    "panel_visible": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/post-push-ci-check.sh",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name promise-nexus-write -- bash /home/axw/ASIF/scripts/promise-nexus-write-hook.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name nexus-question-status-write -- bash /home/axw/ASIF/scripts/nexus-question-status-hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name nexus-question-status-edit -- bash /home/axw/ASIF/scripts/nexus-question-status-hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name promise-bash -- bash /home/axw/ASIF/scripts/promise-bash-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "description": "ASIF /alignment bridge and team identity context",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name team-alignment -- bash /home/axw/ASIF/scripts/asif-team-alignment-context-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "description": "ASIF /alignment bridge and team identity context",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name team-alignment -- bash /home/axw/ASIF/scripts/asif-team-alignment-context-hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name temporal-context -- bash /home/axw/ASIF/scripts/temporal-context.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name dx3-rag -- bash /home/axw/ASIF/scripts/dx3-rag-hook.sh",
            "timeout": 8
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name agent-intelligence-envelope -- bash /home/axw/ASIF/scripts/agent-intelligence-envelope-hook.sh --prompt",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name ai-runway-preflight -- bash /home/axw/ASIF/scripts/ai-runway-preflight-hook.sh",
            "timeout": 8
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name promise-overdue -- bash /home/axw/ASIF/scripts/promise-overdue-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__dx3-cognitive__remember",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name dx3-agent-intelligence-envelope -- bash /home/axw/ASIF/scripts/agent-intelligence-envelope-hook.sh --pretool",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name dx3-dedup -- bash /home/axw/ASIF/scripts/dx3-dedup-hook.sh",
            "timeout": 8
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name pre-compact-governance -- bash /home/axw/ASIF/scripts/pre-compact-governance.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name insight-capture -- bash /home/axw/ASIF/scripts/insight-capture-hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/axw/ASIF/scripts/asif-hook-tap.sh --name promise-stop -- bash /home/axw/ASIF/scripts/promise-stop-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "env": {
    "ASIF_ROOT": "/home/axw/ASIF",
    "ALIGNMENT_AGENT": "vjj"
  },
  "autoMode": {
    "allow": [
      "ASIF Portfolio Scope: project-team Claude sessions operate across this project's repo, ~/ASIF/ (portfolio governance), and ~/.claude/ as a single federated portfolio scope. Reads/writes/deletes within those roots are project scope, not escalation. Does NOT override the 'Irreversible Local Destruction' rule for pre-existing files without explicit user direction."
    ],
    "soft_deny": [],
    "environment": [
      "**Trusted repos**: this project's repo, ~/ASIF/ (portfolio intelligence), ~/.claude/ (agent config)",
      "**Source-control orgs**: nxtg-ai (github.com/nxtg-ai), awaliuddin (github.com/awaliuddin)",
      "**Governance fabric**: directives arrive via .asif/NEXUS.md § CoS Directives; broadcast to peers via ~/ASIF/scripts/alignment-say; Dx3 brain context is injected by the dx3-rag hook below."
    ]
  }
}
